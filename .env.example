# ===========================================
# CORE SERVICES (Required)
# ===========================================

# Discord
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Supabase
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# OpenAI (GPT-5 series access recommended)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key

# Model selection (gpt-5-mini recommended for cost/performance balance)
# Options: gpt-5-mini, gpt-5-nano (cheapest), gpt-5 (most capable)
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_RESEARCH_MODEL=gpt-5-mini

# The Odds API
# Get from: https://the-odds-api.com
ODDS_API_KEY=

# Redis (Upstash recommended, or use local Docker)
# Get from: https://upstash.com or use redis://localhost:6379
REDIS_URL=redis://default:password@your-redis.upstash.io:6379

# ===========================================
# WHOP (Payments - Required for monetization)
# ===========================================
# Get from: https://whop.com/dashboard/settings/developer

WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=

# Product IDs - create products in Whop dashboard
WHOP_PRO_PRODUCT_ID=prod_xxxxx
WHOP_SHARP_PRODUCT_ID=prod_xxxxx

# Your Whop company/store slug (for checkout URLs)
WHOP_COMPANY_SLUG=sharpedge

# ===========================================
# DISCORD ROLES & CHANNELS
# ===========================================
# Create roles and channels in Discord, then copy IDs
# (Enable Developer Mode: Settings → Advanced → Developer Mode)

# Role IDs (right-click role → Copy ID)
FREE_ROLE_ID=
PRO_ROLE_ID=
SHARP_ROLE_ID=

# Channel IDs for alerts (right-click channel → Copy ID)
VALUE_ALERTS_CHANNEL_ID=
LINE_MOVEMENT_CHANNEL_ID=
ARB_ALERTS_CHANNEL_ID=
PM_ALERTS_CHANNEL_ID=

# ===========================================
# PREDICTION MARKETS (Optional)
# ===========================================
# Enable cross-platform arbitrage features

# Kalshi (CFTC-regulated US prediction market)
# Get from: https://kalshi.com - Account → API
# Private key: Generate RSA keypair, upload public key to Kalshi
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# Polymarket (Crypto-based prediction market)
# Get from: https://polymarket.com - may require application
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ===========================================
# DATA ENRICHMENT (Optional but Recommended)
# ===========================================

# WeatherAPI (free tier: 1M calls/month)
# Get from: https://weatherapi.com
WEATHER_API_KEY=

# SportsData.io (paid, for injuries/advanced stats)
# Get from: https://sportsdata.io
SPORTSDATA_API_KEY=

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development

# Webhook server port (for local development)
WEBHOOK_PORT=8000

# Next.js (apps/web) — odds Line shop / Props use a same-origin proxy to FastAPI
# Server-only base URL for the webhook server (no trailing path). Vercel: set this to your deployed API host.
# API_URL=http://127.0.0.1:8000
# Optional: public base for other client-side fetches (value plays, portfolio, etc.)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ===========================================
# LEGACY (Stripe - deprecated, use Whop)
# ===========================================
# These are kept for reference if migrating from Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
# STRIPE_SHARP_PRICE_ID=
